# Luna AI Environment Variables
# Copy this file to .env and fill in your actual values

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=

# AI Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Authentication
JWT_SECRET=
SESSION_SECRET=

# Storage
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# Monitoring
SENTRY_DSN=
